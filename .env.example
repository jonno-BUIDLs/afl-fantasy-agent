# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# AFL Fantasy Auth (cookie from browser Network tab)
# Get this by logging in to fantasy.afl.com.au, opening Network tab,
# filtering for players.json, and copying the full Cookie header value
AFL_FANTASY_COOKIE=your-cookie-string-here

# Optional: X/Twitter (for Phase 3)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
